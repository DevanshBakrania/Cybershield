<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC0A0A0A"
    android:orientation="vertical"
    android:padding="20dp">

    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <TextClock android:id="@+id/wid_date" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:format12Hour="EEE, MMM d" android:format24Hour="EEE, MMM d"
            android:textColor="#888888" android:textSize="14sp" android:textAllCaps="true" android:letterSpacing="0.1"/>

        <TextClock android:id="@+id/wid_time" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_below="@id/wid_date" android:format12Hour="h:mm" android:format24Hour="HH:mm"
            android:textColor="#FFFFFF" android:textSize="48sp" android:textStyle="bold" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_alignParentEnd="true" android:text="⚡" android:textColor="#B2FF59" android:textSize="22sp" />
    </RelativeLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="16dp" android:gravity="center_vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📱" android:textSize="32sp" android:layout_marginEnd="16dp"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="My Device" android:textColor="#B2FF59" android:textSize="18sp" android:textStyle="bold" android:letterSpacing="0.05"/>
            <TextView android:id="@+id/wid_model" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Loading..." android:textColor="#CCCCCC" android:textSize="14sp"/>
            <TextView android:id="@+id/wid_uptime" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Uptime --" android:textColor="#888888" android:textSize="12sp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="24dp" android:baselineAligned="false">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="12dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RAM" android:textColor="#CCCCCC" android:textSize="14sp" android:layout_alignParentStart="true"/>
                <TextView android:id="@+id/wid_ram_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--%" android:textColor="#FFFFFF" android:textSize="14sp" android:layout_alignParentEnd="true" android:textStyle="bold"/>
            </RelativeLayout>
            <ProgressBar android:id="@+id/wid_ram_bar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="8dp" android:layout_marginTop="8dp" android:progressTint="#B2FF59" android:progressBackgroundTint="#333333" android:max="100" android:progress="0"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STORAGE" android:textColor="#CCCCCC" android:textSize="14sp" android:layout_alignParentStart="true"/>
                <TextView android:id="@+id/wid_storage_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--%" android:textColor="#FFFFFF" android:textSize="14sp" android:layout_alignParentEnd="true" android:textStyle="bold"/>
            </RelativeLayout>
            <ProgressBar android:id="@+id/wid_storage_bar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="8dp" android:layout_marginTop="8dp" android:progressTint="#B2FF59" android:progressBackgroundTint="#333333" android:max="100" android:progress="0"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="24dp" android:baselineAligned="false">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BATTERY" android:textColor="#888888" android:textSize="12sp" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/wid_bat_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔋 --%" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TEMP" android:textColor="#888888" android:textSize="12sp" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/wid_temp_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--°C" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DATA" android:textColor="#888888" android:textSize="12sp" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/wid_data_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- MB" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>